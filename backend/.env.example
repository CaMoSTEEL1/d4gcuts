# Server
PORT=4000
NODE_ENV=development

# Security - REQUIRED: generate a strong random secret
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Square payments
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox

# Customer confirmation emails (uses Gmail SMTP by default)
# For Gmail: use an App Password — https://myaccount.google.com/apppasswords
EMAIL_USER=
EMAIL_PASS=
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587

# Twilio SMS notifications
OWNER_PHONE_NUMBER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# CORS - comma-separated allowed origins (e.g. http://localhost:5173,https://yourdomain.com)
ALLOWED_ORIGINS=http://localhost:5173

# Owner registration secret - required to register an OWNER account
OWNER_REGISTRATION_SECRET=

# Admin/Owner portal credentials (change these to update the owner login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
